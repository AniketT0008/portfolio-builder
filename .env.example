# ─────────────────────────────────────────────────────────────
# ProjectForge AI — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# ─────────────────────────────────────────────────────────────

# Supabase ────────────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — SERVER ONLY. Never expose to the browser.
# Used for privileged storage / admin tasks.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Optional model overrides
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_HEAVY=gpt-4o

# App ─────────────────────────────────────────────────────────
# Used for OAuth redirects. In production set to your deployed URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# GitHub (optional) ───────────────────────────────────────────
# A classic/fine-grained PAT raises the public GitHub API rate limit
# when ingesting public repositories. Read-only, public repo scope is enough.
GITHUB_TOKEN=
