# ─────────────────────────────────────────────────────────────
# ProjectForge AI — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# ─────────────────────────────────────────────────────────────

# Supabase ────────────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — SERVER ONLY. Never expose to the browser.
# Used for privileged storage / admin tasks.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini ───────────────────────────────────────────────
# Free API key from https://aistudio.google.com/apikey
# SERVER ONLY — never expose to the browser.
GEMINI_MODEL=your-gemini-api-key
# Optional model name overrides (defaults shown)
GEMINI_MODEL_NAME=gemini-2.5-flash
GEMINI_MODEL_HEAVY=gemini-2.5-flash
# Optional: override the OpenAI-compatible endpoint base URL
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# App ─────────────────────────────────────────────────────────
# Used for OAuth redirects. In production set to your deployed URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# GitHub (optional) ───────────────────────────────────────────
# A classic/fine-grained PAT raises the public GitHub API rate limit
# when ingesting public repositories. Read-only, public repo scope is enough.
GITHUB_TOKEN=
